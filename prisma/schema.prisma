generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["app", "audit", "billing", "catalog", "compat", "content", "notifications", "orders", "returns", "users"]
}

model audit_log {
  log_id      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String?  @db.Uuid
  action      String   @db.VarChar(100)
  entity_type String   @db.VarChar(60)
  entity_id   String?  @db.Uuid
  old_values  Json?
  new_values  Json?
  ip_address  String?  @db.VarChar(45)
  user_agent  String?  @db.VarChar(300)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  user        user?    @relation(fields: [user_id], references: [user_id], onUpdate: NoAction)

  @@index([action], map: "idx_audit_action")
  @@index([created_at(sort: Desc)], map: "idx_audit_created")
  @@index([entity_type, entity_id], map: "idx_audit_entity")
  @@index([new_values], map: "idx_audit_new_values", type: Gin)
  @@index([old_values], map: "idx_audit_old_values", type: Gin)
  @@index([user_id], map: "idx_audit_user")
  @@schema("audit")
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model search_log {
  search_id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id            String?  @db.Uuid
  query              String   @db.VarChar(300)
  filters_applied    Json     @default("{}")
  results_count      Int      @default(0)
  clicked_product_id String?  @db.Uuid
  session_token      String?  @db.VarChar(100)
  ip_address         String?  @db.VarChar(45)
  created_at         DateTime @default(now()) @db.Timestamptz(6)
  user               user?    @relation(fields: [user_id], references: [user_id], onUpdate: NoAction)

  @@index([created_at(sort: Desc)], map: "idx_search_created")
  @@index([query], map: "idx_search_no_res", where: raw("(results_count = 0)"))
  @@index([user_id], map: "idx_search_user")
  @@schema("audit")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model invoice {
  invoice_id         String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id           String         @db.Uuid
  tax_profile_id     String         @db.Uuid
  related_invoice_id String?        @db.Uuid
  invoice_number     String         @unique @db.VarChar(50)
  type               String         @default("invoice") @db.VarChar(15)
  status             String         @default("draft") @db.VarChar(15)
  subtotal           Decimal        @default(0) @db.Decimal(12, 2)
  tax_rate           Decimal        @default(0.16) @db.Decimal(5, 4)
  tax_amount         Decimal        @default(0) @db.Decimal(12, 2)
  total              Decimal        @default(0) @db.Decimal(12, 2)
  currency           String         @default("MXN") @db.Char(3)
  pdf_url            String?        @db.VarChar(500)
  xml_url            String?        @db.VarChar(500)
  issued_at          DateTime?      @db.Timestamptz(6)
  cancelled_at       DateTime?      @db.Timestamptz(6)
  created_at         DateTime       @default(now()) @db.Timestamptz(6)
  order              order          @relation(fields: [order_id], references: [order_id], onDelete: NoAction, onUpdate: NoAction)
  invoice            invoice?       @relation("invoiceToinvoice", fields: [related_invoice_id], references: [invoice_id], onUpdate: NoAction)
  other_invoice      invoice[]      @relation("invoiceToinvoice")
  tax_profile        tax_profile    @relation(fields: [tax_profile_id], references: [tax_profile_id], onDelete: NoAction, onUpdate: NoAction)
  invoice_item       invoice_item[]

  @@index([invoice_number], map: "idx_invoice_number")
  @@index([order_id], map: "idx_invoice_order")
  @@index([related_invoice_id], map: "idx_invoice_related")
  @@index([status], map: "idx_invoice_status")
  @@schema("billing")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model invoice_item {
  invoice_item_id  String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoice_id       String      @db.Uuid
  order_item_id    String?     @db.Uuid
  description      String      @db.VarChar(300)
  quantity         Int         @db.SmallInt
  unit_price       Decimal     @db.Decimal(12, 2)
  tax_rate         Decimal     @default(0.16) @db.Decimal(5, 4)
  discount_amount  Decimal     @default(0) @db.Decimal(12, 2)
  line_total       Decimal     @db.Decimal(12, 2)
  sat_product_code String?     @db.VarChar(20)
  sat_unit_code    String?     @db.VarChar(10)
  invoice          invoice     @relation(fields: [invoice_id], references: [invoice_id], onDelete: Cascade, onUpdate: NoAction)
  order_item       order_item? @relation(fields: [order_item_id], references: [order_item_id], onUpdate: NoAction)

  @@index([invoice_id], map: "idx_invoice_item_invoice")
  @@schema("billing")
}

model tax_profile {
  tax_profile_id String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String    @db.Uuid
  tax_id         String    @db.VarChar(30)
  legal_name     String    @db.VarChar(200)
  fiscal_address String
  tax_regime     String?   @db.VarChar(100)
  cfdi_use       String?   @db.VarChar(10)
  country        String    @default("MX") @db.Char(2)
  is_default     Boolean   @default(false)
  is_verified    Boolean   @default(false)
  created_at     DateTime  @default(now()) @db.Timestamptz(6)
  invoice        invoice[]
  user           user      @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_tax_profile_user")
  @@schema("billing")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model attribute_type {
  attr_type_id                                                              String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                                                                      String               @db.VarChar(100)
  slug                                                                      String               @unique @db.VarChar(100)
  data_type                                                                 String               @db.VarChar(20)
  unit                                                                      String?              @db.VarChar(30)
  filterable                                                                Boolean              @default(false)
  comparable                                                                Boolean              @default(false)
  created_at                                                                DateTime             @default(now()) @db.Timestamptz(6)
  product_attribute                                                         product_attribute[]
  compatibility_rule_compatibility_rule_source_attr_type_idToattribute_type compatibility_rule[] @relation("compatibility_rule_source_attr_type_idToattribute_type")
  compatibility_rule_compatibility_rule_target_attr_type_idToattribute_type compatibility_rule[] @relation("compatibility_rule_target_attr_type_idToattribute_type")

  @@schema("catalog")
}

model brand {
  brand_id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String    @unique @db.VarChar(100)
  slug              String    @unique @db.VarChar(100)
  logo_url          String?   @db.VarChar(500)
  website           String?   @db.VarChar(200)
  country_of_origin String?   @db.Char(2)
  is_active         Boolean   @default(true)
  created_at        DateTime  @default(now()) @db.Timestamptz(6)
  product           product[]

  @@index([slug], map: "idx_brand_slug")
  @@schema("catalog")
}

model category {
  category_id    String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parent_id      String?    @db.Uuid
  name           String     @db.VarChar(100)
  slug           String     @unique @db.VarChar(100)
  description    String?
  icon_url       String?    @db.VarChar(500)
  sort_order     Int        @default(0)
  is_active      Boolean    @default(true)
  level          Int        @default(0) @db.SmallInt
  path           String?    @db.VarChar(500)
  created_at     DateTime   @default(now()) @db.Timestamptz(6)
  updated_at     DateTime   @default(now()) @db.Timestamptz(6)
  category       category?  @relation("categoryTocategory", fields: [parent_id], references: [category_id], onUpdate: NoAction)
  other_category category[] @relation("categoryTocategory")
  product        product[]

  @@index([is_active], map: "idx_category_active")
  @@index([parent_id], map: "idx_category_parent")
  @@index([slug], map: "idx_category_slug")
  @@schema("catalog")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model product {
  product_id                   String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  category_id                  String              @db.Uuid
  brand_id                     String              @db.Uuid
  sku                          String              @unique @db.VarChar(50)
  name                         String              @db.VarChar(200)
  slug                         String              @unique @db.VarChar(200)
  description                  String?
  short_description            String?             @db.VarChar(500)
  base_price                   Decimal             @db.Decimal(12, 2)
  compare_price                Decimal?            @db.Decimal(12, 2)
  cost_price                   Decimal?            @db.Decimal(12, 2)
  weight_kg                    Decimal?            @db.Decimal(8, 3)
  is_active                    Boolean             @default(true)
  is_featured                  Boolean             @default(false)
  requires_compatibility_check Boolean             @default(false)
  avg_rating                   Decimal?            @db.Decimal(3, 2)
  created_at                   DateTime            @default(now()) @db.Timestamptz(6)
  updated_at                   DateTime            @default(now()) @db.Timestamptz(6)
  deleted_at                   DateTime?           @db.Timestamptz(6)
  brand                        brand               @relation(fields: [brand_id], references: [brand_id], onDelete: NoAction, onUpdate: NoAction)
  category                     category            @relation(fields: [category_id], references: [category_id], onDelete: NoAction, onUpdate: NoAction)
  product_attribute            product_attribute[]
  product_image                product_image[]
  product_tag                  product_tag[]
  product_variant              product_variant[]
  product_role                 product_role[]
  promotion_product            promotion_product[]
  review                       review[]
  wishlist                     wishlist[]

  @@index([is_active], map: "idx_product_active")
  @@index([brand_id], map: "idx_product_brand")
  @@index([category_id], map: "idx_product_category")
  @@index([sku], map: "idx_product_sku")
  @@index([slug], map: "idx_product_slug")
  @@schema("catalog")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model product_attribute {
  product_attr_id String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id      String           @db.Uuid
  attr_type_id    String           @db.Uuid
  variant_id      String?          @db.Uuid
  value_text      String?          @db.VarChar(500)
  value_num       Decimal?         @db.Decimal(15, 4)
  attribute_type  attribute_type   @relation(fields: [attr_type_id], references: [attr_type_id], onDelete: NoAction, onUpdate: NoAction)
  product         product          @relation(fields: [product_id], references: [product_id], onDelete: Cascade, onUpdate: NoAction)
  product_variant product_variant? @relation(fields: [variant_id], references: [variant_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([product_id], map: "idx_pattr_product")
  @@index([attr_type_id], map: "idx_pattr_type")
